# GitHub REST API token (repo read scope). recipe-viewer is private.
GITHUB_TOKEN=

# --- LLM provider (story generation + spec authoring) ---
# "claude-cli" routes through your local Claude Code login (no API key needed);
# "anthropic-sdk" uses ANTHROPIC_API_KEY. Auto-detects claude-cli when a binary
# is resolvable, else falls back to the SDK.
LLM_PROVIDER=claude-cli
# Path to the claude binary. Leave blank to use the project dev-dep
# (node_modules/.bin/claude) or a `claude` on PATH.
CLAUDE_CLI_PATH=
# Optional model override for the CLI (defaults to your Claude Code setting).
# CLAUDE_CLI_MODEL=opus

# Only needed if LLM_PROVIDER=anthropic-sdk.
ANTHROPIC_API_KEY=

# ElevenLabs API key + voice for the narration voiceover.
ELEVENLABS_API_KEY=
# The narrator defaults to "Will" (an upbeat premade voice, resolved by name).
# Override if needed:
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_VOICE_NAME=Will

# Optional: override the ffmpeg binary path (defaults to `ffmpeg` on PATH).
# FFMPEG_PATH=
